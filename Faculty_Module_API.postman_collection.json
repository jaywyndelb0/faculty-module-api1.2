				"type": "text/javascript",
				"exec": [
					"if (pm.response.code === 200 || pm.response.code === 201) {",
					"    var jsonData = pm.response.json();",
					"    if (jsonData.token) {",
					"        pm.environment.set(\"auth_token\", jsonData.token);",
					"    }",
					"}"
				]
			}
		}
